<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Sales.Print"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#d2dae2">

    <Grid RowDefinitions="Auto,*,Auto">

        <!--Header-->
        <Border Grid.Row="0" Padding="20,18" StrokeShape="Rectangle" Stroke="Transparent"
                BackgroundColor="DarkCyan">
            <VerticalStackLayout Spacing="0" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="Pembayaran Berhasil" TextColor="White" FontSize="18" FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="Pratinjau struk pembayaran" TextColor="#BFE3E3" FontSize="12"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <!--Konten struk-->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,18" Spacing="14" HorizontalOptions="Center" WidthRequest="380">

                <!--Kartu struk-->
                <Border Padding="0" StrokeShape="RoundRectangle 16" Stroke="Transparent" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.12" Radius="18" Offset="0,6" />
                    </Border.Shadow>

                    <VerticalStackLayout Padding="20,20" Spacing="2">

                        <!--Judul-->
                        <Label Text="STRUK PEMBAYARAN" TextColor="#222" FontSize="16" FontAttributes="Bold"
                               CharacterSpacing="1" HorizontalTextAlignment="Center" />
                        <Label Text="MPos Accurate" TextColor="Grey" FontSize="12"
                               HorizontalTextAlignment="Center" Margin="0,0,0,8" />

                        <BoxView HeightRequest="1" Color="#D9D9D9" HorizontalOptions="Fill" Margin="0,4" />

                        <!--Info transaksi-->
                        <VerticalStackLayout Spacing="4" Margin="0,6,0,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="No. Struk" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelNoStruk" Text="-" TextColor="#222" FontSize="12"
                                       FontAttributes="Bold" HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="No. Faktur" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelNoFaktur" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="Tanggal" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelTanggal" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="Kasir" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelKasir" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="Konsumen" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelKonsumen" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid x:Name="RowSales" ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="Sales" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelSales" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid x:Name="RowPengiriman" ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="Pengiriman" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelPengiriman" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid x:Name="RowAlamat" IsVisible="False" ColumnDefinitions="Auto,*" ColumnSpacing="20">
                                <Label Grid.Column="0" Text="Alamat" TextColor="Grey" FontSize="12" VerticalOptions="Start" />
                                <Label Grid.Column="1" x:Name="LabelAlamat" Text="-" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#D9D9D9" HorizontalOptions="Fill" Margin="0,10,0,2" />

                        <!--Daftar item-->
                        <VerticalStackLayout x:Name="ListItemContainer" BindableLayout.ItemsSource="{Binding .}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Padding="0,6" Spacing="2">
                                        <Label Text="{Binding NamaBarang}" TextColor="#222" FontSize="13" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding QtyAndPrice}" TextColor="Grey" FontSize="12" />
                                            <Label Grid.Column="1" Text="{Binding FormattedLineTotal}" TextColor="#222"
                                                   FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#D9D9D9" HorizontalOptions="Fill" Margin="0,8" />

                        <!--Ringkasan-->
                        <VerticalStackLayout Spacing="5">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Subtotal" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelSubtotal" Text="Rp 0" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid x:Name="RowDiskonFaktur" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Diskon Faktur" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelDiskonFaktur" Text="Rp 0" TextColor="#E74C3C" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>

                            <!--Biaya-biaya (detailExpense)-->
                            <Label x:Name="LabelBiayaHeader" Text="Biaya-biaya" TextColor="Grey" FontSize="12"
                                   IsVisible="False" Margin="0,2,0,0" />
                            <VerticalStackLayout x:Name="ListExpenseContainer" BindableLayout.ItemsSource="{Binding .}" Spacing="3">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" Padding="10,0,0,0">
                                            <Label Grid.Column="0" Text="{Binding detailName}" TextColor="#444" FontSize="12" />
                                            <Label Grid.Column="1" Text="{Binding FormattedAmount}" TextColor="#222" FontSize="12"
                                                   HorizontalTextAlignment="End" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Total Pajak (PPN)" TextColor="Grey" FontSize="12" />
                                <Label Grid.Column="1" x:Name="LabelPajak" Text="Rp 0" TextColor="#222" FontSize="12"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#D9D9D9" HorizontalOptions="Fill" Margin="0,8" />

                        <!--Total-->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="TOTAL" TextColor="DarkCyan" FontSize="15" FontAttributes="Bold"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" x:Name="LabelTotal" Text="Rp 0" TextColor="DarkCyan" FontSize="20"
                                   FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>

                        <!--Kembalian (hanya tunai)-->
                        <Grid x:Name="RowKembalian" IsVisible="False" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <Label Grid.Column="0" Text="Kembalian" TextColor="Goldenrod" FontSize="13" FontAttributes="Bold"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" x:Name="LabelKembalian" Text="Rp 0" TextColor="Goldenrod" FontSize="14"
                                   FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <Label Grid.Column="0" Text="Metode" TextColor="Grey" FontSize="12" />
                            <Label Grid.Column="1" x:Name="LabelMetode" Text="-" TextColor="#222" FontSize="12"
                                   FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>

                        <!--Catatan-->
                        <VerticalStackLayout x:Name="RowCatatan" IsVisible="False" Spacing="2" Margin="0,8,0,0">
                            <Label Text="Catatan" TextColor="Grey" FontSize="12" />
                            <Label x:Name="LabelCatatan" Text="-" TextColor="#444" FontSize="12" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#D9D9D9" HorizontalOptions="Fill" Margin="0,10,0,6" />

                        <Label Text="Terima kasih telah berbelanja" TextColor="Grey" FontSize="12"
                               HorizontalTextAlignment="Center" Margin="0,4,0,0" />

                    </VerticalStackLayout>
                </Border>

                <!--Indikator memuat-->
                <ActivityIndicator x:Name="StrukLoading" IsRunning="False" IsVisible="False"
                                   Color="DarkCyan" HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <!--Tombol bawah: Print / WhatsApp / Skip-->
        <VerticalStackLayout Grid.Row="2" BackgroundColor="White" Padding="16,12,16,16" Spacing="10">
            <VerticalStackLayout.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </VerticalStackLayout.Shadow>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0" x:Name="B_Print" Text="PRINT" Clicked="B_Print_Clicked"
                        BackgroundColor="DodgerBlue" TextColor="White" CornerRadius="12"
                        FontSize="14" FontAttributes="Bold" HeightRequest="50" />
                <Button Grid.Column="1" x:Name="B_Whatsapp" Text="WHATSAPP" Clicked="B_Whatsapp_Clicked"
                        BackgroundColor="#25D366" TextColor="White" CornerRadius="12"
                        FontSize="14" FontAttributes="Bold" HeightRequest="50" />
                <Button Grid.Column="2" x:Name="B_Skip" Text="SKIP" Clicked="B_Skip_Clicked"
                        BackgroundColor="#9E9E9E" TextColor="White" CornerRadius="12"
                        FontSize="14" FontAttributes="Bold" HeightRequest="50" />
            </Grid>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
