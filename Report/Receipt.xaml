<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Report.Receipt"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" NavigationPage.HasNavigationBar="False"
             BackgroundColor="#f8fafa"
             Title="Receipt">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Padding="20,15" StrokeShape="RoundRectangle 10" Margin="10" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </Border.Shadow>
            <toolkit:Expander IsExpanded="False">
                <toolkit:Expander.Header>
                    <StackLayout Orientation="Horizontal">
                        <Label Text="Laporan Penerimaan Kasir" FontSize="20" TextColor="#444" VerticalTextAlignment="Center" FontAttributes="Bold"></Label>
                        <Image Source="chevron100.png" HeightRequest="24" HorizontalOptions="EndAndExpand"></Image>
                    </StackLayout>
                </toolkit:Expander.Header>

                <Grid ColumnDefinitions="*,*" Grid.Row="0" RowDefinitions="Auto,Auto, Auto" ColumnSpacing="10" Margin="0,10">
                    <Label Text="Berdasarkan tanggal" Margin="0,0,0,5" TextColor="Grey"></Label>
                    <Border Grid.Column="0" Grid.Row="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                        <!--buat ini selalu tanggal 1 diawal bulan sekarang-->
                        <DatePicker FontSize="Large" x:Name="DP_startdate"/>
                    </Border>
                    <Border Grid.Column="1" Grid.Row="1"  Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                        <DatePicker FontSize="Large" x:Name="DP_enddate" />
                    </Border>

                    <StackLayout Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,15,0,0">
                        <Label Text="Berdasarkan Kasir" Margin="0,0,0,5" TextColor="Grey"></Label>
                        <Border Grid.Column="1" Grid.Row="1"  Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                            <StackLayout Orientation="Horizontal">
                                
                                <Picker x:Name="PickerNamaKasir" Title="Pilih Nama Kasir" ItemDisplayBinding="{Binding DisplayName}" HorizontalOptions="FillAndExpand"></Picker>
                                <Image Source="chevron100.png" HeightRequest="24" HorizontalOptions="EndAndExpand"></Image>
                            </StackLayout>
                        </Border>

                        <Button Text="GENERATE REPORT" CharacterSpacing="4" 
                                BackgroundColor="DarkCyan"
                                FontAttributes="Bold" Margin="0,20,0,0"
                                x:Name="BtnGenerate" Clicked="BtnGenerate_Clicked"></Button>
                    </StackLayout>
                </Grid>

            </toolkit:Expander>
        </Border>
        
        <!--row 2 desain report-->
    

        <!--row 2 desain report-->
        <ScrollView Grid.Row="1" Orientation="Vertical" Padding="10,0,10,10">
            <VerticalStackLayout Spacing="8">
                <Label Text="Laporan Penerimaan Berdasarkan Kasir"
                       FontSize="18" FontAttributes="Bold" TextColor="#333"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Margin="0,5,0,0"/>
                <Label x:Name="LblPeriode" Text="Per Periode -"
                       FontAttributes="Italic" FontSize="13" TextColor="#666"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <Label x:Name="LblEmptyReport"
                       Text="Pilih rentang tanggal lalu tekan GENERATE REPORT."
                       FontSize="13" TextColor="#999"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Margin="0,30,0,0"/>

                <Border x:Name="ReportBorder" IsVisible="False"
                        Stroke="#333" StrokeThickness="1"
                        StrokeShape="Rectangle" BackgroundColor="White"
                        Margin="0,5,0,0">
                    <Grid x:Name="ReportGrid"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="18" RowSpacing="0"
                          Padding="12,8"/>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>