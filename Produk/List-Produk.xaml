<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Produk.List_Produk"
             BackgroundColor="#f8fafa"
             Title="List_Produk">
    <Grid RowDefinitions="Auto,Auto">
        <!--search-->
        <Border Grid.Row="0" Padding="10" StrokeShape="RoundRectangle 10" Margin="10" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#000000" Opacity="0.10" Radius="12" Offset="0,-3" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border Grid.Column="0" Padding="0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                    <SearchBar Placeholder="Kode Barang atau Nama" x:Name="T_Search" TextChanged="T_Search_TextChanged"></SearchBar>
                </Border>
                <Border Grid.Column="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                    <Image Source="filtersort100.png" HeightRequest="24"></Image>
                </Border>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,*" Grid.Row="1" Margin="10,0" ColumnSpacing="10">
            <Border Grid.Column="0" Padding="0" StrokeShape="RoundRectangle 10" Margin="0" Stroke="WhiteSmoke" 
                    StrokeThickness="1" BackgroundColor="White">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <Image Source="pp100.jpg" Grid.Row="0" HeightRequest="150" Aspect="AspectFill"></Image>
                    <StackLayout Orientation="Horizontal" Grid.Row="1" Margin="10">
                        <Label Text="Produk Rexus Mouse Office Wireless Q30 Black Edition V2 2026" MaxLines="2" WidthRequest="125"
                               LineBreakMode="TailTruncation" Grid.Row="1" TextColor="#444" FontAttributes="Bold"></Label>
                        <Image Source="more50gray.png" HeightRequest="12" Rotation="90" HorizontalOptions="EndAndExpand"></Image>
                    </StackLayout>
                    <Label Text="BRG-00261234001" Grid.Row="2" Margin="10,0" TextColor="Grey" FontSize="Small"></Label>
                    <Label Text="Rp 100.000.000" FontAttributes="Bold" TextColor="Goldenrod" 
                           Margin="0,5,10,10" FontSize="18" Grid.Row="3" HorizontalTextAlignment="End" HorizontalOptions="EndAndExpand"></Label>
                    
                </Grid>
            </Border>
            <Border Grid.Column="1" Padding="0" StrokeShape="RoundRectangle 10" Margin="0" Stroke="WhiteSmoke" 
                    StrokeThickness="1" BackgroundColor="White">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <Image Source="pp100.jpg" Grid.Row="0" HeightRequest="150" Aspect="AspectFill"></Image>
                    <StackLayout Orientation="Horizontal" Grid.Row="1" Margin="10">
                        <Label Text="Produk Rexus Mouse Office Wireless Q30 Black Edition V2 2026" MaxLines="2" WidthRequest="125"
                               LineBreakMode="TailTruncation" Grid.Row="1" TextColor="#444" FontAttributes="Bold"></Label>
                        <Image Source="more50gray.png" HeightRequest="12" Rotation="90" HorizontalOptions="EndAndExpand"></Image>
                    </StackLayout>
                    <Label Text="BRG-00261234001" Grid.Row="2" Margin="10,0" TextColor="Grey" FontSize="Small"></Label>
                    <Label Text="Rp 100.000.000" FontAttributes="Bold" TextColor="Goldenrod" 
                           Margin="0,5,10,10" FontSize="18" Grid.Row="3" HorizontalTextAlignment="End" HorizontalOptions="EndAndExpand"></Label>
                    
                </Grid>
            </Border>
        </Grid>

 
    </Grid>
</ContentPage>