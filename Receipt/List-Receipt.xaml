<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyPosAccurate2026.Receipt.List_Receipt"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             BackgroundColor="#f8fafa" NavigationPage.HasNavigationBar="False"
             Title="Daftar Transaksi">

    <Grid RowDefinitions="Auto, *,Auto">
        <!-- Search & Filter Header -->

            
        <Border Grid.Row="0" Padding="10" StrokeShape="RoundRectangle 10" Margin="10" Stroke="Transparent" StrokeThickness="0.5" BackgroundColor="White">
            <toolkit:Expander IsExpanded="False">
                <toolkit:Expander.Header>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Border Grid.Column="0" Padding="0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                        <SearchBar Placeholder="Nomor Penerimaan" x:Name="T_Search"></SearchBar>
                    </Border>
                    <Border Grid.Column="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="WhiteSmoke">
                        <Image Source="filtersort100.png" HeightRequest="24"></Image>
                    </Border>
                </Grid>
            </toolkit:Expander.Header>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,*" Grid.Row="0" RowDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,10">
                        <Label Text="Berdasarkan tanggal" Margin="0,0,0,5" TextColor="Grey"></Label>
                        <Border Grid.Column="0" Grid.Row="1" Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                            <DatePicker FontSize="Large" x:Name="DP_startdate"/>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="1"  Padding="10,0" StrokeShape="RoundRectangle 10"  Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
                            <DatePicker FontSize="Large" x:Name="DP_enddate"/>
                        </Border>
                    </Grid>
                    <!--cara bayar, ganti ke collectionview nanti-->
                    <Grid ColumnDefinitions="Auto,Auto" Grid.Row="1"  RowDefinitions="Auto,Auto" ColumnSpacing="1" Margin="0,0,0,10">
                        <Label Text="Berdasarkan cara bayar" Margin="0,0,0,5" TextColor="Grey"></Label>
                        <Border Grid.Column="0" Grid.Row="1" Padding="10" StrokeShape="RoundRectangle 15"  
                                Stroke="Transparent" HorizontalOptions="Start" StrokeThickness="0.5" BackgroundColor="DarkCyan">
                            <Label Text="Semua" TextColor="White" Margin="10,0" FontAttributes="Bold" HorizontalTextAlignment="Center"></Label>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="1"  Padding="10" StrokeShape="RoundRectangle 15"  Stroke="DarkCyan" 
                                StrokeThickness="0.5" HorizontalOptions="Start" BackgroundColor="Transparent">
                            <Label Text="Tunai" TextColor="DarkCyan" Margin="10,0" FontAttributes="Bold" HorizontalTextAlignment="Center"></Label>
                        </Border>
                    </Grid>
                    <!--konsumen, data dari pelanggan/list.php-->
                    <StackLayout Grid.Row="2" Spacing="5" Margin="0,0,0,10">
                        <Label Text="Berdasarkan konsumen" Margin="0,0,0,5" TextColor="Grey"></Label>
                        <CollectionView x:Name="CV_Konsumen" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" StrokeShape="RoundRectangle 15" Stroke="DarkCyan"
                                            StrokeThickness="0.5" HorizontalOptions="Start" BackgroundColor="Transparent">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnKonsumenTapped"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="DarkCyan"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding name}" Margin="10,0" FontAttributes="Bold"
                                               HorizontalTextAlignment="Center" TextColor="DarkCyan">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="White"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>

                </Grid>
            </toolkit:Expander>
        </Border>
        
        <!--data receipt pakai listview/collection view. scroll able-->

        <Border Padding="20,15" Grid.Row="1" Margin="10,0" VerticalOptions="Start" StrokeShape="RoundRectangle 10" Stroke="#CCCCCC" StrokeThickness="0.5" BackgroundColor="White">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <StackLayout Grid.Column="0" Grid.Row="0">
                    <Label Text="110103.2026.06.00027" FontAttributes="Bold" FontSize="18" TextColor="#444"></Label>
                    <Label Text="20/06/2026" TextColor="Grey"></Label>
                </StackLayout>
                <StackLayout Grid.Column="1" Grid.Row="0">
                    <Border Grid.Column="0" Grid.Row="1" Padding="10,5" StrokeShape="RoundRectangle 5"  
                            Stroke="Transparent" HorizontalOptions="End" StrokeThickness="0.5" BackgroundColor="CadetBlue">

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Image Source="bank100white.png" HeightRequest="10"></Image>
                            <Label Text="TRANSFER BANK" VerticalTextAlignment="Center" TextColor="White"></Label>
                        </StackLayout>
                        
                       
                    </Border>
                    <Label Text="Rp 50.000.000" Margin="0,5,0,0" TextColor="DarkCyan" FontAttributes="Bold" FontSize="26" HorizontalOptions="EndAndExpand"></Label>
                </StackLayout>

                <Line X2="360" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Stroke="#CFCFCF" StrokeThickness="1.4" StrokeDashArray="3,3"
                        HorizontalOptions="Fill" />
                <StackLayout Grid.Column="0" Grid.Row="2">
                  
                    <Label Text="Kasir" TextColor="Grey"></Label>
                    <Label Text="Administrator 01" FontAttributes="Bold" FontSize="18" TextColor="#444"></Label>
                </StackLayout>
                <StackLayout Grid.Column="1" Grid.Row="2">
                  
                    <Label Text="Customer" TextColor="Grey" HorizontalOptions="End"></Label>
                    <Label Text="Shopee" HorizontalOptions="End" FontAttributes="Bold" FontSize="18" TextColor="#444"></Label>
                </StackLayout>

            </Grid>
        </Border>


    </Grid>
</ContentPage>